{
  "name": "nifty-league",
  "license": "UNLICENSED",
  "version": "1.0.5",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "deploy": "graph deploy --node https://api.studio.thegraph.com/deploy/ nifty-league-sepolia",
    "create-local": "graph create --node http://localhost:8020/ nifty-league-sepolia",
    "remove-local": "graph remove --node http://localhost:8020/ nifty-league-sepolia",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 nifty-league-sepolia",
    "test": "bun test bun-tests",
    "test:coverage": "node scripts/check-coverage.mjs",
    "audit": "bash scripts/audit.sh",
    "dev": "graph create --node http://localhost:8020/ nifty-league-sepolia && graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 nifty-league-sepolia",
    "start": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 nifty-league-sepolia",
    "type:check": "tsc --noEmit",
    "test:graph": "graph test --version 0.6.0"
  },
  "devDependencies": {
    "@assemblyscript/loader": "^0.28.19",
    "@eslint/js": "10.0.1",
    "@graphprotocol/graph-cli": "0.98.1",
    "@graphprotocol/graph-ts": "0.38.2",
    "assemblyscript": "0.19.23",
    "eslint": "10.7.0",
    "lint-staged": "17.1.0",
    "matchstick-as": "0.6.0",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.65.0",
    "wabt": "1.0.39",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "undici": "7.28.0",
    "immutable": "5.1.5",
    "glob": "11.1.0",
    "yaml": "2.8.3",
    "js-yaml": "4.2.0",
    "cross-spawn": "7.0.5",
    "ejs": "3.1.10",
    "semver": "7.8.5",
    "uuid": "11.1.1"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": "24.18.0"
  }
}
