{
  "name": "nifty-league",
  "license": "UNLICENSED",
  "version": "1.0.5",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "deploy": "graph deploy --node https://api.studio.thegraph.com/deploy/ nifty-league-sepolia",
    "create-local": "graph create --node http://localhost:8020/ nifty-league-sepolia",
    "remove-local": "graph remove --node http://localhost:8020/ nifty-league-sepolia",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 nifty-league-sepolia",
    "test": "graph test",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "type:check": "tsc --noEmit",
    "start": "graph deploy-local",
    "dev": "graph deploy-local --watch",
    "prepare": "husky",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "0.97.1",
    "@graphprotocol/graph-ts": "0.38.1"
  },
  "devDependencies": {
    "matchstick-as": "0.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "packageManager": "bun@1.3.14",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml,css}": "bunx prettier --write --ignore-unknown"
  }
}
